$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 480);

    #Title {
      $C.@Title #TitleLabel {
        @Text = "";
      }
    }

    #Content {
      Padding: (Vertical: 30, Horizontal: 40);

      Label #Message {
        Text: "";
        Style: (FontSize: 16, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Center, Wrap: true);
        Anchor: (Bottom: 18);
      }

      Group {
        LayoutMode: Center;
        Anchor: (Top: 10);

        $C.@CancelTextButton #ExitButton {
          Text: "";
          FlexWeight: 1;
        }
      }
    }
  }
}
