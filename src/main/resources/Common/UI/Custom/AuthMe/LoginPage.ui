$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 460);

    #Title {
      $C.@Title #TitleLabel {
        @Text = "";
      }
    }

    #Content {
      Padding: (Vertical: 30, Horizontal: 40);

      Label #Welcome {
        Text: "";
        Style: (FontSize: 16, TextColor: $C.@ColorDefaultLabel, HorizontalAlignment: Center, Wrap: true);
        Anchor: (Bottom: 14);
      }

      Label #PasswordLabel {
        Text: "";
        Style: (RenderBold: true, RenderUppercase: true, TextColor: #94a7bb);
      }

      $C.@TextField #PasswordInput {
        Anchor: (Top: 8, Height: 44);
        PlaceholderText: "";
      }

      Label #Error {
        Style: (RenderBold: true, TextColor: #bb3333, HorizontalAlignment: Center, Wrap: true);
        Anchor: (Top: 10);
        Visible: false;
      }

      Group {
        LayoutMode: Center;
        Anchor: (Top: 18);

        $C.@TextButton #LoginButton {
          Text: "";
          FlexWeight: 1;
        }
      }

      Label #Hint {
        Text: "";
        Style: (FontSize: 12, TextColor: $C.@ColorGrayCaption, HorizontalAlignment: Center, Wrap: true);
        Anchor: (Top: 16);
      }
    }
  }
}
